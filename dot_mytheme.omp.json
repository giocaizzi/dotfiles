{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#ffa5d8",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "<#7eb8da>\u250c</>[<#ffffff>\ueb99</> {{ .UserName }} from <#ffffff>\uf108</> {{ .HostName }}]",
          "type": "session"
        },
        {
          "foreground": "#ffa5d8",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "[\uf0e7]",
          "type": "root"
        },
        {
          "foreground": "#F05032",
          "options": {
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "[<#ffffff>{{ .UpstreamIcon }}</>{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} <#ffffff>\uf044</> {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} <#ffffff>\uf046</> {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} <#ffffff>\ueb4b</> {{ .StashCount }}{{ end }}]",
          "type": "git"
        },
        {
          "foreground": "#ffffff",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "[\ue235 {{ if .Venv }}{{ .Venv }} {{ .Full }}{{ end }}]",
          "type": "python"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "overflow": "break",
      "segments": [
        {
          "foreground": "#ffffff",
          "foreground_templates": [
            "{{ if (gt (subf 1 (divf (.PhysicalFreeMemory|float64) (.PhysicalTotalMemory|float64))) 0.2) }}#fff34e{{else}}#ffa5d8{{end}}"
          ],
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "[<#ffffff>\ue266</> RAM: {{ (div ((sub .PhysicalTotalMemory .PhysicalFreeMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB]",
          "type": "sysinfo"
        },
        {
          "foreground": "#ffffff",
          "foreground_templates": [
            "{{if eq \"Charging\" .State.String}}#b8e994{{end}}",
            "{{if eq \"Discharging\" .State.String}}#fff34e{{end}}",
            "{{if eq \"Full\" .State.String}}#33DD2D{{end}}"
          ],
          "options": {
            "cache_duration": "none",
            "charged_icon": "\uf240 ",
            "charging_icon": "\uf1e6 ",
            "discharging_icon": "\ue234 "
          },
          "style": "plain",
          "template": "{{ if not .Error }}[{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }}\uf295]",
          "type": "battery"
        },
        {
          "options": {
            "cache_duration": "none",
            "time_format": "15:04 PM Mon 02 Jan"
          },
          "style": "plain",
          "template": "[{{ .CurrentDate | date .Format }}]",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "options": {
            "cache_duration": "none"
          },
          "foreground": "#7eb8da",
          "style": "plain",
          "template": "{{ if .Name }}<#7eb8da>| </>[<#ffffff>\uebd8</> {{.User.Name}}::{{ .Name }}]{{ end }}",
          "type": "az"
        },
        {
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "{{ if .DefaultEnvironment }}[\uebd8 {{ .DefaultEnvironment }}]{{ end }}",
          "type": "azd"
        },
        {
          "foreground": "#F4B400",
          "style": "plain",
          "template": "{{ if .Project }}[<#ffffff></> {{.Account}}::{{.Project}}]{{ end }}",
          "type": "gcp"
        },
        {
          "foreground": "#ffa5d8",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "{{ if .Profile }}[{{ .Profile }}{{if .Region}}@{{ .Region }}{{ end }}]{{ end }}",
          "type": "aws"
        },
        {
          "foreground": "#ffa5d8",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "{{ if .Context }}[{{.Context}}{{if .Namespace}}::{{.Namespace}}{{end}}]{{ end }}",
          "type": "kubectl"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#ffa5d8",
          "options": {
            "cache_duration": "none",
            "style": "full"
          },
          "template": "<#7eb8da>|</> [<#ffffff>\uf07c</>  {{ .Path }}]",
          "type": "path"
        },
        {
          "foreground": "#ffa5d8",
          "options": {
            "cache_duration": "none",
            "style": "dallas",
            "threshold": 0
          },
          "style": "plain",
          "template": "[<#ffffff>\uf252</> {{ .FormattedMs }}s]",
          "type": "executiontime"
        },
        {
          "foreground": "#ffa5d8",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "[<#ffffff>\uea6c</> Error, check your command]",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#7eb8da",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "\u2514Δ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}
