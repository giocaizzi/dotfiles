{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#cba6f7",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "<#89b4fa>\u250c</>[<#cdd6f4>\ueb99</> {{ .UserName }} from <#cdd6f4>\uf108</> {{ .HostName }}]",
          "type": "session"
        },
        {
          "foreground": "#cba6f7",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "[\uf0e7]",
          "type": "root"
        },
        {
          "foreground": "#f38ba8",
          "options": {
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "[<#cdd6f4>{{ .UpstreamIcon }}</>{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} <#cdd6f4>\uf044</> {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} <#cdd6f4>\uf046</> {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} <#cdd6f4>\ueb4b</> {{ .StashCount }}{{ end }}]",
          "type": "git"
        },
        {
          "foreground": "#cdd6f4",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "[\ue235 {{ if .Venv }}{{ .Venv }} {{ .Full }}{{ end }}]",
          "type": "python"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "overflow": "break",
      "segments": [
        {
          "foreground": "#cdd6f4",
          "foreground_templates": [
            "{{ if (gt (subf 1 (divf (.PhysicalFreeMemory|float64) (.PhysicalTotalMemory|float64))) 0.2) }}#f9e2af{{else}}#cba6f7{{end}}"
          ],
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "[<#cdd6f4>\ue266</> RAM: {{ (div ((sub .PhysicalTotalMemory .PhysicalFreeMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB]",
          "type": "sysinfo"
        },
        {
          "foreground": "#cdd6f4",
          "foreground_templates": [
            "{{if eq \"Charging\" .State.String}}#a6e3a1{{end}}",
            "{{if eq \"Discharging\" .State.String}}#f9e2af{{end}}",
            "{{if eq \"Full\" .State.String}}#a6e3a1{{end}}"
          ],
          "options": {
            "cache_duration": "none",
            "charged_icon": "\uf240 ",
            "charging_icon": "\uf1e6 ",
            "discharging_icon": "\ue234 "
          },
          "style": "plain",
          "template": "{{ if not .Error }}[{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }}\uf295]",
          "type": "battery"
        },
        {
          "options": {
            "cache_duration": "none",
            "time_format": "15:04 PM Mon 02 Jan"
          },
          "style": "plain",
          "template": "[{{ .CurrentDate | date .Format }}]",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "options": {
            "cache_duration": "none"
          },
          "foreground": "#89b4fa",
          "style": "plain",
          "template": "{{ if .Name }}<#89b4fa>| </>[<#cdd6f4>\uebd8</> {{.User.Name}}::{{ .Name }}]{{ end }}",
          "type": "az"
        },
        {
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "{{ if .DefaultEnvironment }}[\uebd8 {{ .DefaultEnvironment }}]{{ end }}",
          "type": "azd"
        },
        {
          "foreground": "#f9e2af",
          "style": "plain",
          "template": "{{ if .Project }}[<#cdd6f4></> {{.Account}}::{{.Project}}]{{ end }}",
          "type": "gcp"
        },
        {
          "foreground": "#cba6f7",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "{{ if .Profile }}[{{ .Profile }}{{if .Region}}@{{ .Region }}{{ end }}]{{ end }}",
          "type": "aws"
        },
        {
          "foreground": "#cba6f7",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "{{ if .Context }}[{{.Context}}{{if .Namespace}}::{{.Namespace}}{{end}}]{{ end }}",
          "type": "kubectl"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#cba6f7",
          "options": {
            "cache_duration": "none",
            "style": "full"
          },
          "template": "<#89b4fa>|</> [<#cdd6f4>\uf07c</>  {{ .Path }}]",
          "type": "path"
        },
        {
          "foreground": "#cba6f7",
          "options": {
            "cache_duration": "none",
            "style": "dallas",
            "threshold": 0
          },
          "style": "plain",
          "template": "[<#cdd6f4>\uf252</> {{ .FormattedMs }}s]",
          "type": "executiontime"
        },
        {
          "foreground": "#cba6f7",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "[<#cdd6f4>\uea6c</> Error, check your command]",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#89b4fa",
          "options": {
            "cache_duration": "none"
          },
          "style": "plain",
          "template": "\u2514Δ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}
