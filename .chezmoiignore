# ------------- General -------------
# This is a .chezmoiignore file, which specifies files and directories that are to be ignored by chezmoi.
# For more information, see https://chezmoi.io/docs/reference/chezmoiignore/
# Note: Conditions are logically inverted
# so that the files are ignored on the platform they are not intended for
# ------------------------------------
# --- chezmoi repo  ---
README.md
# --- secrets (user-managed, never tracked) ---
.secrets
CLAUDE.md
AGENTS.md
.claude
.agents
docs
apps/

# ------------------------------------
# Optionals:
# These ignores depends upon user configuration choices prompted during setup. 
# ------------------------------------
# --- AI Assistants (optional) ---
{{ if not .syncAIAssistants }}
# User opted out of AI assistant setup
.claude/**
.chezmoiscripts/03-sync-ai-assistants.sh
.chezmoiscripts/03-sync-ai-assistants.ps1
{{ else }}
# Ignore managed repos - they are cloned/pulled via scripts
.claude/skills/**
{{ end }}

# ------------------------------------
# Machine specific ignores:
# These files are specific to certain operating systems and should be ignored on others.
# ------------------------------------
# --- macOS ---
# if not on mac, ignore these macos specific files
{{ if ne .chezmoi.os "darwin" }}
# vscode settings are in Library
**/Library/
**/Library/**/*
# ZSH config files
.zshrc
.zprofile
{{ end }}


# --- Unix-like systems (macOS + Linux) ---
# Ignore bash scripts on Windows (uses PowerShell)
{{ if eq .chezmoi.os "windows" }}
.chezmoiscripts/03-sync-ai-assistants.sh
.chezmoiscripts/env.sh
.chezmoiscripts/install-pkgs.sh
{{ end }}

# --- windows ---
# if not on windows, ignore Windows-specific files
{{ if ne .chezmoi.os "windows" }}
## PowerShell profile lives in OneDrive Docs
**/OneDrive - Jakala SpA/
**/OneDrive - Jakala SpA/**/*
# VSCode settings in app data
**/AppData/
**/AppData/**/*
## Scripts
.chezmoiscripts/03-sync-ai-assistants.ps1
.chezmoiscripts/env.ps1
{{ end }}
