# ============================================================================
# .chezmoiignore — paths to EXCLUDE from chezmoi management
# ============================================================================
# Logic is INVERTED: list entries to ignore. Template-aware.
# Reference: https://chezmoi.io/docs/reference/chezmoiignore/
# ============================================================================

# ----------------------------------------------------------------------------
# Repo meta — never apply
# ----------------------------------------------------------------------------
README.md
AGENTS.md
CLAUDE.md
.agents
.secrets
docs

# Symlink-only sources: files that exist in the source tree purely as targets
# for symlinks on the OS that uses them, and should never be deployed as
# regular files anywhere.
.config/windows-terminal
.config/powershell/profile.ps1

# Sourcetree and other GUIs rewrite ~/.gitconfig directly. We manage git via
# the XDG location (~/.config/git/config). Both are read by git.
.gitconfig

# ============================================================================
# OS-conditional sections
# Pattern: paths live under the OS's native location and are ignored elsewhere.
#
#   macOS    →  Library/Application Support/...
#   Linux    →  .config/...
#   Windows  →  AppData/... (+ OneDrive for PowerShell)
# ============================================================================

# --- not macOS ---
{{ if ne .chezmoi.os "darwin" }}
Library
.zshrc
.zprofile
{{ end }}

# --- not Linux ---
# VS Code (Code, Code - Insiders) and Ghostty live under ~/.config on Linux.
# On macOS they live under Library; on Windows under AppData.
{{ if ne .chezmoi.os "linux" }}
.config/ghostty
.config/Code
.config/Code - Insiders
{{ end }}

# --- not Windows ---
{{ if ne .chezmoi.os "windows" }}
AppData
OneDrive - Jakala SpA
.config/powershell
.chezmoiscripts/init-untracked-env.ps1
.chezmoiscripts/install-pkgs.ps1
{{ end }}

# --- Windows only ---
# Bash setup scripts are Unix-only. The .config/shell snippets and POSIX rc
# files (.profile, .bashrc, .bash_profile) ARE kept so Git Bash and WSL users
# get the same aliases/PATH as native Unix.
{{ if eq .chezmoi.os "windows" }}
.chezmoiscripts/init-untracked-env.sh
.chezmoiscripts/install-pkgs.sh
{{ end }}
