#!/bin/bash
# Sync Copilot agents repositories with latest changes

set -e

# ==================== Configuration ====================
REPO_OWNER="giocaizzi"
BRANCH="main"
BASE_TARGET_DIR="{{ .chezmoi.homeDir }}/.copilot/agents"

# Array of repositories to sync: "repo_name:target_subdir:exclude_files"
# If target_subdir is ".", files go directly to BASE_TARGET_DIR
# exclude_files is comma-separated list (optional)
REPOS=(
    "ralph-copilot:.:README.md"
    # Add more repos here as needed:
    # "another-agent-repo:subdir:README.md,LICENSE"
)
# =======================================================

# Clone repository with SSH fallback to HTTPS
clone_repo() {
    local ssh_url="$1"
    local https_url="$2"
    local temp_target="$3"
    
    if git clone -q --depth 1 --branch "$BRANCH" "$ssh_url" "$temp_target" 2>/dev/null; then
        return 0
    elif git clone -q --depth 1 --branch "$BRANCH" "$https_url" "$temp_target" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

# Copy files excluding .git and specified files
copy_content() {
    local src="$1"
    local dest="$2"
    shift 2
    local exclude_files=("$@")
    
    mkdir -p "$dest"
    
    # Build rsync exclude pattern
    local rsync_opts=(-a --delete --exclude=".git")
    for file in "${exclude_files[@]}"; do
        rsync_opts+=(--exclude="$file")
    done
    
    rsync "${rsync_opts[@]}" "$src/" "$dest/"
}

# Calculate content hash (excluding .git)
get_content_hash() {
    local dir="$1"
    find "$dir" -type f -not -path "*/\.git/*" -exec shasum {} \; 2>/dev/null | sort | shasum | cut -d' ' -f1
}

# Sync a single repository
sync_repo() {
    local repo_name="$1"
    local target_subdir="$2"
    local exclude_str="$3"
    
    # Parse exclude files
    local exclude_files=()
    if [ -n "$exclude_str" ]; then
        IFS=',' read -ra exclude_files <<< "$exclude_str"
    fi
    
    # Build URLs
    local repo_url_ssh="git@github.com-giocaizzi:${REPO_OWNER}/${repo_name}.git"
    local repo_url_https="https://github.com/${REPO_OWNER}/${repo_name}.git"
    
    # Determine target directory
    local target_dir
    if [ "$target_subdir" = "." ]; then
        target_dir="$BASE_TARGET_DIR"
    else
        target_dir="$BASE_TARGET_DIR/$target_subdir"
    fi
    
    # Create temp directory for this repo
    local temp_dir="$(mktemp -d)"
    
    echo "📦 Syncing ${repo_name}..."
    
    if clone_repo "$repo_url_ssh" "$repo_url_https" "$temp_dir"; then
        # Store old hash if target exists
        local old_hash=""
        [ -d "$target_dir" ] && old_hash=$(get_content_hash "$target_dir")
        
        # Copy content (excluding .git and specified files)
        copy_content "$temp_dir" "$target_dir" "${exclude_files[@]}"
        
        # Check if content changed
        local new_hash=$(get_content_hash "$target_dir")
        if [ "$old_hash" != "$new_hash" ]; then
            echo "✅ ${repo_name} synced successfully"
        else
            echo "✅ ${repo_name} already up to date"
        fi
    else
        echo "⚠️  Failed to sync ${repo_name} repository"
    fi
    
    # Cleanup temp directory
    rm -rf "$temp_dir"
}

# Main logic
mkdir -p "$BASE_TARGET_DIR"

# Process each repository
for repo_entry in "${REPOS[@]}"; do
    IFS=':' read -r repo_name target_subdir exclude_files <<< "$repo_entry"
    sync_repo "$repo_name" "$target_subdir" "$exclude_files"
done
