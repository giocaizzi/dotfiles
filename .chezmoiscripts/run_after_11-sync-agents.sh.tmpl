#!/bin/bash
# Sync Copilot agents repository with latest changes (excluding README)

set -e

{{ if ne .chezmoi.os "windows" }}
AGENTS_TARGET="{{ .chezmoi.homeDir }}/.copilot/agents"

# Create .copilot directory if it doesn't exist
mkdir -p "{{ .chezmoi.homeDir }}/.copilot"

# If agents doesn't exist or is not a git repo, clone it
if [ ! -d "$AGENTS_TARGET/.git" ]; then
    echo "📦 Cloning vscode-ralph repository (agents)..."
    
    # Remove if it exists but is not a git repo
    if [ -d "$AGENTS_TARGET" ]; then
        rm -rf "$AGENTS_TARGET"
    fi
    
    # Clone the vscode-ralph repository
    if git clone -q git@github.com:giocaizzi/vscode-ralph.git "$AGENTS_TARGET" 2>/dev/null; then
        echo "✅ Agents repository cloned successfully"
        # Remove README.md to avoid confusion with main repo
        if [ -f "$AGENTS_TARGET/README.md" ]; then
            rm "$AGENTS_TARGET/README.md"
            echo "🗑️  Removed README.md from agents"
        fi
    else
        echo "⚠️  Failed to clone agents repository (check SSH keys)"
        exit 0  # Don't fail chezmoi apply
    fi
else
    # Repository exists, check for updates
    cd "$AGENTS_TARGET"
    
    # Fetch updates quietly
    if git fetch -q origin main 2>/dev/null; then
        LOCAL=$(git rev-parse @)
        REMOTE=$(git rev-parse @{u})
        
        if [ "$LOCAL" != "$REMOTE" ]; then
            echo "🔄 Updating agents repository..."
            if git pull -q origin main 2>/dev/null; then
                echo "✅ Agents updated successfully"
                # Remove README.md after update
                if [ -f "$AGENTS_TARGET/README.md" ]; then
                    rm "$AGENTS_TARGET/README.md"
                    echo "🗑️  Removed README.md from agents"
                fi
            else
                echo "⚠️  Failed to update agents (may have local changes)"
            fi
        fi
    fi
fi
{{ end }}
