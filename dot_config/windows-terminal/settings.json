            "colorScheme": "Catppuccin Mocha",
            "cursorShape": "filledBox",
            "useAcrylic": true,
            "opacity": 85,
            "padding": "6, 4",
            "scrollbarState": "hidden",
            "antialiasingMode": "cleartype",
            "experimental.retroTerminalEffect": false
        },
