# ============================================================================
# SHARED SHELL ALIASES (POSIX)
# ============================================================================
# Generated by chezmoi from .chezmoidata/shortcuts.toml — DO NOT EDIT directly.
# Sourced by ~/.profile. POSIX-compliant: bash + zsh + sh.
# ============================================================================

# --- Directory navigation ---
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# --- File listing (color-aware) ---
if ls --color=auto >/dev/null 2>&1; then
	alias ls='ls --color=auto'
else
	alias ls='ls -G'  # BSD ls (macOS)
fi
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'

# --- File ops & system ---
alias mkdir='mkdir -p'
alias df='df -h'
alias du='du -h'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# --- Platform-specific ---
{{- if eq .chezmoi.os "darwin" }}
alias free='top -l 1 -s 0 | grep PhysMem'
{{- end }}

# --- Python ---
if command -v python3 >/dev/null 2>&1; then
	alias python='python3'
fi

# --- Git shortcuts (generated from .chezmoidata/shortcuts.toml) ---
{{ range $name, $cmd := .shortcuts.git -}}
alias {{ $name }}='{{ $cmd }}'
{{ end }}
