# Ghostty 1.3.x - macOS Configuration
# https://ghostty.org/docs/config/reference

# --- Font ---
font-family = JetBrainsMono Nerd Font
font-size = 14
font-thicken = true
adjust-cell-height = 1

# --- Theme (auto light/dark) ---
theme = dark:Catppuccin Mocha,light:Catppuccin Latte

# --- Window ---
background-opacity = 0.85
background-blur = true
window-padding-x = 4,2
window-padding-y = 6,0
window-save-state = always
confirm-close-surface = false

# --- macOS ---
macos-titlebar-style = hidden
macos-option-as-alt = right
macos-icon = official
macos-window-shadow = true

# --- Cursor ---
cursor-style = block
cursor-style-blink = false

# --- Shell ---
shell-integration = detect
shell-integration-features = no-cursor
mouse-hide-while-typing = true
mouse-reporting = false
scrollback-limit = 1000000

# --- Scrollbar ---
scrollbar = never

# --- Clipboard ---
clipboard-read = allow
clipboard-write = allow

# --- Splits ---
unfocused-split-opacity = 0.7
split-inherit-working-directory = true

# --- Quick Terminal ---
quick-terminal-position = top
quick-terminal-animation-duration = 0.08

# --- Notifications ---
notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
notify-on-command-finish-after = 5s

# --- Keybindings ---
# Quick terminal (global)
keybind = global:cmd+grave_accent=toggle_quick_terminal

# Vim-style split navigation
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

# Split management (ctrl+a leader, tmux-like)
keybind = ctrl+a>h=new_split:left
keybind = ctrl+a>j=new_split:down
keybind = ctrl+a>k=new_split:up
keybind = ctrl+a>l=new_split:right
keybind = ctrl+a>f=toggle_split_zoom
keybind = ctrl+a>e=equalize_splits

# Utility
keybind = super+i=inspector:toggle
keybind = super+r=reload_config
