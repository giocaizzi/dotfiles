{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "ReadFile",
      "ListFiles",
      "SearchInFiles",
      "WebSearch",
      "WebFetch",
      "Bash",
      "EditFile",
      "WriteFile",
      "CreateFile",
      "DeleteFile",
      "Git",
      "RunTests"
    ],
    "deny": [
      "DangerousShell",
      "SystemReboot"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "python@giocaizzi-skills": true,
    "api@giocaizzi-skills": true,
    "javascript@giocaizzi-skills": true,
    "dev-tools@giocaizzi-skills": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true{{ if eq .chezmoi.os "darwin" }},
    "greenhouse@greenhouse": true,
    "firefly-iii@firefly-iii": true{{ end }}
  },
  "extraKnownMarketplaces": {
    "giocaizzi-skills": {
      "source": {
        "source": "github",
        "repo": "giocaizzi/skills"
      },
      "autoUpdate": true
    }{{ if eq .chezmoi.os "darwin" }},
    "greenhouse": {
      "source": {
        "source": "github",
        "repo": "giocaizzi/greenhouse"
      },
      "autoUpdate": true
    },
    "firefly-iii": {
      "source": {
        "source": "git",
        "url": "https://github.com/giocaizzi/firefly-iii.git",
        "ref": "feat/mcp-integration"
      }
    }{{ end }}
  },
  "effortLevel": "xhigh",
  "theme": "dark",
  "remoteControlAtStartup": false,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
