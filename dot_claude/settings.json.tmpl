{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_TRACES_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otel.giocaizzi.xyz",
    "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "cumulative",
    "OTEL_RESOURCE_ATTRIBUTES": "service.namespace=claude-code,deployment.environment.name=production"{{ if eq .chezmoi.os "windows" }},
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"{{ end }}
  },
  "permissions": {
    "allow": [
      "ReadFile",
      "ListFiles",
      "SearchInFiles",
      "WebSearch",
      "WebFetch",
      "Bash",
      "EditFile",
      "WriteFile",
      "CreateFile",
      "DeleteFile",
      "Git",
      "RunTests"
    ],
    "deny": [
      "DangerousShell",
      "SystemReboot",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/.aws/credentials)",
      "Read(**/.aws/config)",
      "Read(**/.ssh/**)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/credentials.json)",
      "Read(**/service-account*.json)",
      "Read(**/gcp-key*.json)",
      "Read(**/*.kubeconfig)",
      "Read(**/kubeconfig)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets/**)",
      "Edit(**/.aws/credentials)",
      "Edit(**/.ssh/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)",
      "Write(**/.aws/credentials)",
      "Write(**/.ssh/**)",
      "Bash(env)",
      "Bash(printenv:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": []
  },
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  {{ if eq .chezmoi.os "windows" }}
  "defaultShell": "powershell",
  {{ end }}
  "enabledPlugins": {
    "python@giocaizzi-skills": true,
    "api@giocaizzi-skills": true,
    "javascript@giocaizzi-skills": true,
    "dev-tools@giocaizzi-skills": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true{{ if eq .chezmoi.os "darwin" }},
    "greenhouse@greenhouse": true,
    "firefly-iii@firefly-iii": true{{ end }}
  },
  "extraKnownMarketplaces": {
    "giocaizzi-skills": {
      "source": {
        "source": "github",
        "repo": "giocaizzi/skills"
      },
      "autoUpdate": true
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      },
      "autoUpdate": true
    }{{ if eq .chezmoi.os "darwin" }},
    "greenhouse": {
      "source": {
        "source": "github",
        "repo": "giocaizzi/greenhouse"
      },
      "autoUpdate": true
    },
    "firefly-iii": {
      "source": {
        "source": "git",
        "url": "https://github.com/giocaizzi/firefly-iii.git",
        "ref": "feat/mcp-integration"
      }
    }{{ end }}
  },
  "effortLevel": "xhigh",
  "theme": "dark",
  "remoteControlAtStartup": false,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
