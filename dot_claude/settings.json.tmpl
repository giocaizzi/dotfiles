{
  "permissions": {
    "allow": [
      "ReadFile",
      "ListFiles",
      "SearchInFiles",
      "WebSearch",
      "WebFetch",
      "Bash",
      "EditFile",
      "WriteFile",
      "CreateFile",
      "DeleteFile",
      "Git",
      "RunTests"
    ],
    "deny": [
      "DangerousShell",
      "SystemReboot"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    {{ if eq .chezmoi.os "darwin" }}"frontend-design@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "ddd@giocaizzi-skills": true,
    "fastapi@giocaizzi-skills": true,
    "sqlalchemy@giocaizzi-skills": true,
    "python-development@giocaizzi-skills": true,
    "python-testing@giocaizzi-skills": true,
    "react@giocaizzi-skills": true,
    "nextjs@giocaizzi-skills": true,
    "javascript-typescript@giocaizzi-skills": true,
    "smart-refactor@giocaizzi-skills": true,
    "agents@giocaizzi-skills": true{{ end }}
  },
  "extraKnownMarketplaces": {
    "giocaizzi-skills": {
      "source": {
        "source": "github",
        "repo": "giocaizzi/skills"
      }
    }
  },
  "skipAutoPermissionPrompt": true
}
