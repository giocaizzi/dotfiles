{
  "permissions": {
    "allow": [
      "ReadFile",
      "ListFiles",
      "SearchInFiles",
      "WebSearch",
      "WebFetch",
      "Bash",
      "EditFile",
      "WriteFile",
      "CreateFile",
      "DeleteFile",
      "Git",
      "RunTests"
    ],
    "deny": [
      "DangerousShell",
      "SystemReboot"
    ],
    "defaultMode": "auto"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "python@giocaizzi-skills": true,
    "api@giocaizzi-skills": true,
    "javascript@giocaizzi-skills": true,
    "frontend-design@claude-plugins-official": true{{ if eq .chezmoi.os "darwin" }},
    "figma@claude-plugins-official": true{{ end }}
  },
  "extraKnownMarketplaces": {
    "giocaizzi-skills": {
      "source": {
        "source": "github",
        "repo": "giocaizzi/skills"
      }    
    }
  },
  "skipAutoPermissionPrompt": true,
  "effortLevel": "xhigh"
}
