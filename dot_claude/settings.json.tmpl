{
  "permissions": {
    "allow": [
      "ReadFile",
      "ListFiles",
      "SearchInFiles",
      "WebSearch",
      "WebFetch",
      "Bash",
      "EditFile",
      "WriteFile",
      "CreateFile",
      "DeleteFile",
      "Git",
      "RunTests"
    ],
    "deny": [
      "DangerousShell",
      "SystemReboot"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    {{ if eq .chezmoi.os "darwin" }}"frontend-design@claude-plugins-official": true,
    "figma@claude-plugins-official": true{{ end }}
  },
  {{ if eq .chezmoi.os "darwin" }}"extraKnownMarketplaces": {
    "giocaizzi-skills": {
      "source": {
        "source": "github",
        "repo": "giocaizzi/skills"
      }
    }
  },{{ end }}
  "skipAutoPermissionPrompt": true
}
