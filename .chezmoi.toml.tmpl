{{- $user := promptStringOnce . "user" "User name" -}}
{{- $email := promptStringOnce . "email" "Email address" -}}

[data]
    gitUser = {{ $user | quote }}
    gitEmail = {{ $email | quote }}

[git]
    autoAdd = true
    autoCommit = true
    autoPush = true

# Configures `chezmoi merge`: the 3-way merge tool used to reconcile drift
# between source (chezmoi), target (rendered) and destination (home) files.
# Unrelated to git's merge configuration.
[merge]
{{- if eq .chezmoi.os "windows" }}
    command = "vim"
    args = [
        "-d",
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]
{{- end }}
{{- if eq .chezmoi.os "darwin" }}
    command = "vimdiff"
    args = [
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]
{{- end }}
    
